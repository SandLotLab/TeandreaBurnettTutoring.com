new file mode 100644
index 0000000000000000000000000000000000000000..647f33a4f59eac078059bf4be273e9ab323d5ba1
--- /dev/null
+++ b/css/styles.css
@@ -0,0 +1,79 @@
+:root {
+  --plum: #6a4c93;
+  --teal: #2a9d8f;
+  --sun: #f4a261;
+  --sky: #eaf7ff;
+  --ink: #263143;
+  --card: #ffffff;
+  --line: #d9dfee;
+}
+* { box-sizing: border-box; }
+body {
+  margin: 0;
+  font-family: "Nunito", "Segoe UI", Arial, sans-serif;
+  color: var(--ink);
+  background: linear-gradient(180deg, #fdf9ff 0%, var(--sky) 100%);
+  line-height: 1.55;
+}
+a { color: var(--plum); }
+.container { width: min(1100px, 92%); margin: 0 auto; }
+.stack > * + * { margin-top: 1rem; }
+.site-header { background: linear-gradient(90deg, var(--plum), var(--teal)); position: sticky; top: 0; z-index: 10; }
+.nav-wrap { display: flex; align-items: center; justify-content: space-between; padding: .8rem 0; }
+.brand { color: #fff; text-decoration: none; font-weight: 800; }
+.nav-links { list-style: none; display: flex; gap: 1rem; margin: 0; padding: 0; }
+.nav-links a { color: #fff; text-decoration: none; font-weight: 700; }
+.nav-links a[aria-current='page'] { color: #ffe5c8; }
+
+.hero { display: grid; grid-template-columns: 2fr 1fr; gap: 1rem; padding: 2rem 0; }
+.hero-panel, .card {
+  background: var(--card);
+  border: 1px solid var(--line);
+  border-radius: 16px;
+  padding: 1rem;
+  box-shadow: 0 8px 20px rgba(73, 74, 117, 0.08);
+}
+.eyebrow {
+  display: inline-block; background: #f2ebff; color: #4d3179;
+  padding: .22rem .65rem; border-radius: 99px; font-weight: 800; font-size: .84rem;
+}
+.grid { display: grid; gap: 1rem; }
+.grid-2 { grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); }
+.btn {
+  border: 0; border-radius: 10px; padding: .68rem 1rem; text-decoration: none; cursor: pointer;
+  font-weight: 800; display: inline-block; background: var(--plum); color: #fff;
+}
+.btn:hover { background: #56377c; }
+.btn-light { background: #e8f8f6; color: #1a5f56; }
+.button-row,.copy-row,.socials,.share-row { display: flex; gap: .7rem; flex-wrap: wrap; align-items: center; }
+.youtube-link {
+  font-weight: 800;
+  color: #b2071d;
+  text-decoration: underline;
+}
+.social-chip {
+  background: #ecfbf8;
+  border: 1px solid #c7ebe5;
+  color: #11655d;
+  border-radius: 999px;
+  padding: .35rem .7rem;
+  text-decoration: none;
+  font-weight: 700;
+}
+.note-box { border-left: 4px solid var(--sun); background: #fff4ea; padding: .75rem; border-radius: 8px; }
+input,textarea,select { width: 100%; padding: .55rem; border: 1px solid #bfcde0; border-radius: 8px; font: inherit; }
+label { display: grid; gap: .25rem; font-weight: 700; }
+.legend,.small-note { color: #506278; font-size: .92rem; }
+.slot-grid { display:grid; grid-template-columns: repeat(auto-fit, minmax(170px,1fr)); gap:.6rem; }
+.slot { border:1px solid #c9d7ea; background:#f6fbff; border-radius:10px; padding:.65rem; text-align:left; }
+.slot.active { outline: 3px solid #9ed9d1; }
+.slot.full { background:#fbecee; border-color:#e6b6bd; color:#7f2131; }
+.site-footer { margin-top: 2rem; background: #22344d; color:#eef5ff; padding: 1rem 0; }
+.footer-grid { display:flex; justify-content:space-between; align-items:center; gap:1rem; }
+.footer-grid ul { list-style:none; display:flex; gap:.8rem; flex-wrap:wrap; margin:0; padding:0; }
+.footer-grid a { color:#eef5ff; text-decoration:none; }
+
+@media (max-width: 780px) {
+  .hero { grid-template-columns: 1fr; }
+  .footer-grid { flex-direction: column; align-items: flex-start; }
+}
