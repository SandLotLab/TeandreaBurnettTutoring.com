+    <link rel="canonical" href="https://teandreaburnetttutoring.com/" />
+    <meta property="og:title" content="TeAndrea Burnett Tutoring | Troy, Alabama" />
+    <meta property="og:description" content="Local teacher-led tutoring for 1st and 2nd grade students in Troy, AL." />
+    <meta property="og:type" content="website" />
+    <meta property="og:url" content="https://teandreaburnetttutoring.com/" />
